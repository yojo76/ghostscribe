# GhostScribe server environment file.
# Copy this to /etc/ghostscribe/server.env and edit to taste.
# All variables are optional; defaults are shown on the right.

# Network
GHOSTSCRIBE_HOST=0.0.0.0
GHOSTSCRIBE_PORT=5005

# Model + GPU
GHOSTSCRIBE_MODEL=large-v3-turbo
GHOSTSCRIBE_DEVICE=cuda
# int8_float16 is fastest on modern NVIDIA with essentially no quality loss.
# Use float16 if you need slightly higher fidelity; int8 for CPU fallback.
# Known issue: on Blackwell (sm_120, e.g. RTX 5060 Ti) with ctranslate2 4.7.x,
# int8_float16 fails mid-inference with CUBLAS_STATUS_NOT_SUPPORTED. Use
# float16 on Blackwell until a newer ctranslate2 wheel ships the fix.
GHOSTSCRIBE_COMPUTE_TYPE=int8_float16

# Logging (absolute path recommended when running under systemd)
GHOSTSCRIBE_LOG_PATH=/opt/ghostscribe/server/logs/ghostscribe_server.log

# Upload guard (in megabytes)
GHOSTSCRIBE_MAX_UPLOAD_MB=25

# Optional shared-secret auth. If unset/empty, auth is disabled.
# If set, clients must send: X-Auth-Token: <value>
#GHOSTSCRIBE_AUTH_TOKEN=replace-me-with-a-long-random-string
